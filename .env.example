# Copy to .env and fill in. The orchestrator reads these at runtime.
#
# Division of labour: GPT-5.5 is the researcher (collectors), Claude is the
# architect/administrator (verifier adjudication, escalation, scoring, KB import).

# ── Which mode ────────────────────────────────────────────────────────────────
# gpt    = research (collectors) + default verification on GPT-5.5; escalate to Claude on a flag
# claude = collectors + verification fully on Claude (runs here now; in-house quality baseline)
# Override per run with: python -m src.orchestrator --mode gpt
AGENT_MODE=gpt

# ── Claude engine (used in claude mode, and for escalation in gpt mode) ───────
# Works here with `ant auth login` OR an exported ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8
ESCALATION_MODEL=claude-opus-4-8
USE_WEB_SEARCH=1

# ── Research engine: GPT-5.5 (used in gpt mode) ───────────────────────────────
# The designated researcher. OpenAI Responses API + web_search tool = real web
# research. Paste your OpenAI key and confirm the exact model string ("gpt-5.5")
# from the OpenAI dashboard. CHEAP_BASE_URL can point at any OpenAI-compatible
# endpoint if you host GPT-5.5 elsewhere; leave blank for OpenAI.
CHEAP_BASE_URL=
CHEAP_MODEL=gpt-5.5
CHEAP_API_KEY=

# ── Grok engine: xAI (third ⚡ provider; OpenAI-compatible endpoint) ──────────
# Research uses xAI Live Search server-side. Get a key at https://console.x.ai
GROK_API_KEY=
GROK_MODEL=grok-4.20-0309-reasoning
GROK_BASE_URL=

# ── DeepSeek engine (4th ⚡ provider; browses via the app's own web tools —
#     set SEARCH_API_KEY below for quantitative research) ──────────────────────
# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=

# ── App-side web tools (used by DeepSeek quantitative research) ───────────────
# DeepSeek has no server-side search — the app supplies web_search/fetch_url
# itself, authenticated by this key. Free tier: https://api-dashboard.search.brave.com
SEARCH_API_KEY=
SEARCH_PROVIDER=brave

# ── Optional: token pricing for the run summary's cost estimate ──────────────
# USD per 1M tokens (e.g. DeepSeek: 0.27 in / 1.10 out). Leave blank to hide
# the cost line — it is only computed from RECORDED usage, never guessed.
TOKEN_PRICE_IN=
TOKEN_PRICE_OUT=
